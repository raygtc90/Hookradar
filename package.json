{
  "name": "hookradar",
  "version": "1.0.0",
  "type": "module",
  "description": "🛰️ Open Source Webhook Tester & Debugger — Inspect, debug, and replay webhooks in real-time",
  "keywords": [
    "webhook",
    "tester",
    "debugger",
    "inspector",
    "http",
    "api",
    "realtime",
    "open-source"
  ],
  "author": "HookRadar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aniketmishra-0/Hookradar.git"
  },
  "bin": {
    "hookradar": "./bin/hookradar.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/server.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server/server.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "inquirer": "^13.3.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "vite": "^5.4.21"
  }
